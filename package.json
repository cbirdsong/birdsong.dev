{
	"name": "internet-web-site",
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"start": "npm run watch",
		"watch": "npm-run-all --parallel watch:sass watch:css watch:11ty",
		"build": "npm-run-all build:sass build:css build:11ty",
		"watch:11ty": "ELEVENTY_ENV=dev npx eleventy --serve",
		"build:11ty": "ELEVENTY_ENV=prod npx eleventy",
		"watch:sass": "sass --load-path=node_modules --watch src/scss:src/css && sass --load-path=node_modules --watch src/themes/1976/scss:src/themes/1976/css",
		"build:sass": "sass --load-path=node_modules src/scss:src/css && sass --load-path=node_modules src/themes/1976/scss:src/themes/1976/css",
		"watch:css": "postcss src/css/*.css --dir src/css --watch --map --use autoprefixer && postcss src/themes/1976/css/*.css --dir src/css --watch --map --use autoprefixer",
		"build:css": "postcss src/css/*.css --dir src/css --map --use autoprefixer cssnano && postcss src/themes/1976/css/*.css --dir src/css --map --use autoprefixer cssnano",
		"debug": "DEBUG=* npx eleventy"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/cbirdsong/internet-web-site"
	},
	"author": {
		"name": "Cory Birdsong",
		"email": "cory@birdsong.dev",
		"url": "https://birdsong.dev/"
	},
	"bugs": {
		"url": "https://github.com/cbirdsong/internet-web-site/issues"
	},
	"homepage": "https://github.com/cbirdsong/internet-web-site",
	"devDependencies": {
		"@11ty/eleventy": "^3.1.2",
		"@11ty/eleventy-navigation": "^1.0.5",
		"@11ty/eleventy-plugin-inclusive-language": "^1.0.3",
		"@11ty/eleventy-plugin-rss": "^2.0.4",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
		"@fontsource/azeret-mono": "^5.2.11",
		"@fontsource/jost": "^5.2.8",
		"autoprefixer": "^10.4.2",
		"clean-css": "^5.2.2",
		"cssnano": "^7.1.3",
		"luxon": "^3.7.2",
		"markdown-it-anchor": "^9.2.0",
		"markdown-it-footnote": "^4.0.0",
		"markdown-it": "^14.1.1",
		"normalize.css": "^8.0.1",
		"npm-run-all": "^4.1.5",
		"postcss-cli": "^11.0.1",
		"postcss": "^8.4.31",
		"prettier": "^3.8.1",
		"prism-themes": "^1.9.0",
		"prismjs": "^1.30.0",
		"sass": "^1.48.0",
		"wrangler": "^4.71.0"
	}
}
